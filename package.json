{
  "name": "ontrack-cli",
  "version": "0.3.0",
  "description": "CLI for Monash OnTrack / Doubtfire",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "ontrack": "./dist/cli.js"
  },
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.json && node -e \"require('node:fs').chmodSync('dist/cli.js', 0o755)\"",
    "dev": "tsx src/cli.ts",
    "test": "node --import tsx --test test/**/*.test.ts",
    "smoke:real": "npm run build && node scripts/smoke-real.mjs",
    "clean": "rimraf dist",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  },
  "keywords": [
    "ontrack",
    "doubtfire",
    "cli"
  ],
  "files": [
    "dist"
  ],
  "dependencies": {
    "playwright-core": "^1.58.2"
  }
}
